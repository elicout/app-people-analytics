# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local

# NextAuth JWT signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Required for local HTTP dev (non-HTTPS)
AUTH_TRUST_HOST=true

# OpenAI API key — used by the AI chat assistant (gpt-4o-mini)
# The app starts without it, but the AI panel will return 500 errors.
OPENAI_API_KEY=

# Data source — "mock" (default) uses in-memory DuckDB with seeded data.
# Leave unset or set to "mock" for local development.
# DATA_SOURCE=mock
